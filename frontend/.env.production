# Frontend Production Configuration
PORT=3000

# Disable ESLint strict mode in Netlify CI build
DISABLE_ESLINT_PLUGIN=true

# Backend API Configuration - Points to Render deployment
REACT_APP_API_URL=https://scrapair.onrender.com/api

# WebSocket Configuration - Points to Render deployment
REACT_APP_SOCKET_URL=https://scrapair.onrender.com

# Application Mode
REACT_APP_ENV=production
