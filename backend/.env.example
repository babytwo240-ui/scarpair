# ========================================
# SCRAPAIR BACKEND ENVIRONMENT VARIABLES
# COMPLETE CONFIGURATION FOR SUPABASE + S3 STORAGE
# ========================================
# Copy this file to .env and fill in your actual values

# ========================================
# SERVER CONFIGURATION
# ========================================
NODE_ENV=development
PORT=5000

# Backend Base URL (used for service references, emails, console logs)
# Must match frontend's API endpoint
BACKEND_BASE_URL=http://localhost:5000

# Frontend URL (for password reset links and redirects)
FRONTEND_BASE_URL=http://localhost:3000

# ========================================
# CORS CONFIGURATION
# ========================================
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ========================================
# DATABASE (Supabase PostgreSQL)
# Get these from: https://app.supabase.com/project/[PROJECT_ID]/settings/database
# ========================================
DB_HOST=your_supabase_db_host.supabase.co
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=your_supabase_database_password

# ========================================
# JWT AUTHENTICATION
# Generate a strong secret: openssl rand -base64 32
# ========================================
JWT_SECRET=your_super_secret_jwt_key_at_least_32_characters_long_here

# ========================================
# ADMIN JWT AUTHENTICATION
# Must match the ADMIN JWT_SECRET in admin backend .env
# ========================================
ADMIN_JWT_SECRET=scrapair_admin_local_secret_key_change_in_production
ADMIN_JWT_EXPIRATION=24h

# ========================================
# REDIS (for caching, rate limiting, sessions)
# ========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_if_any
REDIS_SSL=false

# ========================================
# SUPABASE STORAGE (for image uploads)
# Get these from: https://app.supabase.com/project/[PROJECT_ID]/settings/api
# ========================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
SUPABASE_STORAGE_BUCKET=message-images

# API URL for test scripts
# Used by test-password-security.js and other test utilities
API_URL=http://localhost:5000/api

# ========================================
# EMAIL CONFIGURATION
# LOCAL: Use Ethereal (testing email service)
# PRODUCTION: Replace with SendGrid, AWS SES, etc.
# ========================================
EMAIL_SERVICE=ethereal
EMAIL_FROM=noreply@scrapair.com

# Ethereal Email Configuration (Local Development Only)
# Get free account: https://ethereal.email
# Then configure nodemailer with the credentials
ETHEREAL_HOST=smtp.ethereal.email
ETHEREAL_PORT=587
ETHEREAL_USER=your_ethereal_username@ethereal.email
ETHEREAL_PASSWORD=your_ethereal_password

# Password Reset Configuration
RESET_TOKEN_EXPIRATION=3600
PASSWORD_RESET_CODE_EXPIRY=900

# ========================================
# FRONTEND & BACKEND URLS
# ========================================
# Backend Base URL for service references and logs
BACKEND_BASE_URL=http://localhost:5000

# Frontend Base URL for password reset links and redirects
FRONTEND_BASE_URL=http://localhost:3000

# API URL for test scripts
API_URL=http://localhost:5000/api

# ========================================
# LOGGING CONFIGURATION
# ========================================
