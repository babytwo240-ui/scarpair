# ========================================
# SCRAPAIR ADMIN BACKEND - ENVIRONMENT VARIABLES
# ========================================
# Copy this file to .env.local for local development
# Copy this file to .env.production for production

# ========================================
# SERVER CONFIGURATION
# ========================================
NODE_ENV=development
PORT=5498

# ========================================
# DATABASE CONFIGURATION
# MUST BE THE SAME DATABASE as Main Backend (postgres)
# Get credentials from: https://app.supabase.com/project/[PROJECT_ID]/settings/database
# ========================================
DB_HOST=aws-1-ap-northeast-1.pooler.supabase.com
DB_PORT=6543
DB_USER=postgres
DB_PASSWORD=your_supabase_database_password
DB_NAME=postgres

# ========================================
# CORS CONFIGURATION
# ========================================
CORS_ORIGIN=http://localhost:4000

# ========================================
# JWT AUTHENTICATION
# Generate with: openssl rand -base64 32
# ========================================
JWT_SECRET=scrapair_admin_local_secret_key_change_in_production
JWT_EXPIRATION=24h

# ========================================
# MAIN BACKEND CONFIGURATION
# URL of the main Scrapair backend (required for notifications)
# ========================================
MAIN_BACKEND_URL=http://localhost:5000

# ========================================
# ADMIN BACKEND BASE URL
# Used for console logs and service references
# ========================================
ADMIN_BACKEND_BASE_URL=http://localhost:5498

# ========================================
# ADMIN NOTIFICATIONS
# Secret key for securing admin notification endpoints
# ========================================
ADMIN_NOTIFICATION_KEY=dev_admin_notification_secret_key
