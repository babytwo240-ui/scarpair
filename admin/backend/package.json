{
  "name": "scrapair-admin-backend",
  "version": "1.0.0",
  "description": "Scrapair Admin Backend - JWT Authentication & Full Material Management",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node -r tsconfig-paths/register dist/index.js",
    "dev": "ts-node --project tsconfig.json src/index.ts",
    "dev:watch": "node -r tsconfig-paths/register -r ts-node/register --watch-extensions ts src/index.ts",
    "test": "echo \"Error: no test specified\" && exit 1",
    "db:migrate": "sequelize-cli db:migrate",
    "db:migrate:undo": "sequelize-cli db:migrate:undo"
  },
  "keywords": [
    "admin",
    "scrapair",
    "jwt"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "pg": "^8.18.0",
    "sequelize": "^6.35.2",
    "sequelize-cli": "^6.6.1",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@cspotcode/source-map-support": "^0.8.1",
    "@tsconfig/node22": "^22.0.5",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/morgan": "^1.9.10",
    "@types/node": "^20.10.6",
    "nodemon": "^3.1.11",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.3.3"
  }
}
